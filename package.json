{
  "name": "postchi",
  "version": "1.0.2",
  "description": "",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "electron .",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "vite build && electron-builder"
  },
  "build": {
    "appId": "ir.ameer.postchi",
    "productName": "Postchi",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "ameer",
      "repo": "postchi"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/x-date-pickers": "^9.5.0",
    "@uiw/react-codemirror": "^4.25.10",
    "consola": "^3.4.2",
    "dayjs": "^1.11.21",
    "lottie-web": "^5.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0"
  }
}
